\name{chart_libraries}
\alias{chart_libraries}
\alias{chart_types}
\alias{cf_supported}
\title{Supported renderers and chart types}
\usage{
chart_libraries()
chart_types()
cf_supported()
}
\value{\code{chart_libraries()} returns renderer identifiers, display labels, pinned versions, licence names and URLs, bundle policies, downstream-use notices, related R-package hints, and official documentation URLs. \code{chart_types()} returns chart-type identifiers. \code{cf_supported()} returns the full renderer-by-type grid.}
\description{Lists the JavaScript charting libraries and chart types supported by the ChartForge R API and app, including the renderer-specific licence and asset-delivery policy used by generated HTML.}
